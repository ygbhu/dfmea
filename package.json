{
  "name": "dfmea-workspace",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=24",
    "pnpm": ">=10.33.2"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter @dfmea/api --filter @dfmea/web dev",
    "build": "pnpm -r --workspace-concurrency=1 --sort build",
    "test": "pnpm build && node scripts/run-tests.mjs",
    "e2e": "playwright test",
    "lint": "pnpm -r --sort lint",
    "typecheck": "pnpm build && pnpm -r --workspace-concurrency=1 --sort typecheck",
    "format": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml,css,html}\"",
    "db:migrate": "pnpm --filter @dfmea/api db:migrate"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  }
}

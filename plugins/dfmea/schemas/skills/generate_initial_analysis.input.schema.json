{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "dfmea.generate_initial_analysis.input.v1",
  "title": "Generate Initial DFMEA Analysis Input",
  "type": "object",
  "properties": {
    "project_id": {
      "type": "string"
    },
    "goal": {
      "type": "string"
    },
    "scope_id": {
      "type": "string"
    },
    "focus": {
      "type": "string"
    },
    "scope": {
      "type": "object",
      "additionalProperties": true
    },
    "knowledge_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": ["project_id"],
  "additionalProperties": true
}
